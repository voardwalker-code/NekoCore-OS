node_modules/
.env
*.log
.DS_Store
Thumbs.db

# API keys and runtime config — copy Config/ma-config.example.json and fill in yours
Config/ma-config.json

# Auth runtime data — generated at startup
server/data/accounts.json
server/data/sessions.json
server/data/checkouts.json

# Browser runtime data — generated by browser app
server/data/browser-history.json
server/data/browser-bookmarks.json
server/data/browser-session.json
server/data/browser-settings.json
server/data/browser-research-sessions.json
server/data/nekocore-audit.ndjson

# Entity runtime data — generated when entities are created
/entities/*
!/entities/.gitkeep

# Root system memory — generated at runtime
/memories/*
!/memories/.gitkeep

# Local backup and restore artifacts
/tmp-backups/*
!/tmp-backups/.gitkeep
/restore-snapshots/*
!/restore-snapshots/.gitkeep
/server/data/restore-snapshots/*
!/server/data/restore-snapshots/.gitkeep

# Server entity runtime state
/server/entity/*
!/server/entity/.gitkeep

# Workspace runtime data
/workspace/**

# Skill workspace runtime dirs
skills/*/workspace/*
!skills/*/workspace/.gitkeep

# IDE
.vscode/
*.code-workspace
