{
  "name": "nekocore",
  "version": "0.6.0",
  "description": "NekoCore OS - A Cognitive WebOS for persistent AI identity, episodic memory, autonomous brain cycles, and layered reasoning. Built on the REM System (Recursive Echo Memory).",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "reset": "node reset-all.js",
    "audit:memory-schema": "node server/tools/audit-legacy-memory-records.js",
    "backfill:memory-schema": "node server/tools/audit-legacy-memory-records.js --apply",
    "audit:document-backfill": "node server/tools/backfill-legacy-document-chunks.js",
    "backfill:document-chunks": "node server/tools/backfill-legacy-document-chunks.js --apply",
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js"
  },
  "keywords": [
    "ai",
    "memory",
    "cognitive-architecture",
    "dream-engine",
    "identity",
    "llm"
  ],
  "author": "voardwalker-code",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voardwalker-code/NekoCore-OS.git"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "gif-encoder-2": "^1.0.5"
  }
}
