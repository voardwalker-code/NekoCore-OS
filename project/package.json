{
  "name": "nekocore",
  "version": "0.9.0-alpha.5",
  "description": "NekoCore OS - A Cognitive WebOS for persistent AI identity, episodic memory, autonomous brain cycles, and layered reasoning. Built on the REM System (Recursive Echo Memory).",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "start:bg": "node neko-start.js",
    "stop": "node neko-start.js --stop",
    "status": "node neko-start.js --status",
    "kill-all": "node kill-all.js",
    "reset": "node reset-all.js",
    "installer:apply": "node server/tools/installer-cli.js install",
    "installer:remove": "node server/tools/installer-cli.js uninstall",
    "audit:memory-schema": "node server/tools/audit-legacy-memory-records.js",
    "backfill:memory-schema": "node server/tools/audit-legacy-memory-records.js --apply",
    "audit:document-backfill": "node server/tools/backfill-legacy-document-chunks.js",
    "backfill:document-chunks": "node server/tools/backfill-legacy-document-chunks.js --apply",
    "migrate:memory-agents": "node server/tools/migrate-memory-agents.js",
    "test": "node --test tests/unit/*.test.js tests/integration/*.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:integration": "node --test tests/integration/*.test.js",
    "map": "node scripts/generate-system-map.js",
    "validate": "node scripts/validate-dynamic-patterns.js"
  },
  "keywords": [
    "ai",
    "memory",
    "cognitive-architecture",
    "dream-engine",
    "identity",
    "llm"
  ],
  "author": "voardwalker-code",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/voardwalker-code/NekoCore-OS.git"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.96",
    "gif-encoder-2": "^1.0.5"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
