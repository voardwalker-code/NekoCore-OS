{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nekocore/contracts/vfs-drive-mapping",
  "title": "VFS Drive Mapping Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "defaultDrive", "roots", "resolverPolicy"],
  "properties": {
    "contractVersion": {
      "type": "string",
      "minLength": 1
    },
    "defaultDrive": {
      "type": "string",
      "const": "C:"
    },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/root"
      }
    },
    "resolverPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["missingPathBehavior", "pathTraversalProtection"],
      "properties": {
        "missingPathBehavior": {
          "type": "string",
          "enum": ["return-not-found"]
        },
        "pathTraversalProtection": {
          "type": "string",
          "enum": ["deny-outside-root"]
        }
      }
    }
  },
  "$defs": {
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "mount", "absolutePath"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mount": {
          "type": "string",
          "minLength": 1
        },
        "absolutePath": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
