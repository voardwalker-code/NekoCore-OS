{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "nekocore://client/js/apps/system-apps.schema.json",
  "title": "System Apps Manifest",
  "type": "object",
  "required": ["version", "lastUpdated", "apps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "minLength": 1
    },
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "apps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/app" }
    }
  },
  "$defs": {
    "launchMode": {
      "type": "string",
      "enum": ["embedded", "standalone", "both", "both+standalone", "both+nested-standalone"]
    },
    "appType": {
      "type": "string",
      "enum": ["shell-inline", "shell-html", "iframe-page", "hybrid-shell-html", "hybrid-iframe-page", "installer-html"]
    },
    "embedded": {
      "type": "object",
      "required": ["tabId", "target"],
      "additionalProperties": false,
      "properties": {
        "tabId": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$"
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "hostPath": {
          "type": "string"
        },
        "navTarget": {
          "type": "string"
        }
      }
    },
    "popout": {
      "type": "object",
      "required": ["eligible"],
      "additionalProperties": false,
      "properties": {
        "eligible": { "type": "boolean" },
        "queryParam": { "type": "string" },
        "excludedReason": { "type": "string" }
      }
    },
    "installerHooks": {
      "type": "object",
      "required": ["managed", "createFile", "deleteFile", "registrationAnchors"],
      "additionalProperties": false,
      "properties": {
        "managed": { "type": "boolean" },
        "createFile": { "type": "boolean" },
        "deleteFile": { "type": "boolean" },
        "entryIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "registrationAnchors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["file", "owner"],
            "additionalProperties": false,
            "properties": {
              "file": { "type": "string", "minLength": 1 },
              "owner": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "app": {
      "type": "object",
      "required": [
        "id",
        "name",
        "icon",
        "sourcePath",
        "appType",
        "defaultWindow",
        "standalonePath",
        "optional",
        "launchMode",
        "embedded",
        "popout",
        "ownership"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "icon": {
          "type": "string",
          "minLength": 1
        },
        "sourcePath": {
          "type": "string",
          "minLength": 1
        },
        "appType": { "$ref": "#/$defs/appType" },
        "defaultWindow": {
          "type": "object",
          "required": ["width", "height"],
          "additionalProperties": false,
          "properties": {
            "width": { "type": "integer", "minimum": 1 },
            "height": { "type": "integer", "minimum": 1 }
          }
        },
        "standalonePath": {
          "type": ["string", "null"]
        },
        "packagePath": {
          "type": ["string", "null"]
        },
        "packageEntry": {
          "type": ["string", "null"]
        },
        "optional": {
          "type": "boolean"
        },
        "launchMode": { "$ref": "#/$defs/launchMode" },
        "embedded": { "$ref": "#/$defs/embedded" },
        "popout": { "$ref": "#/$defs/popout" },
        "ownership": {
          "type": "object",
          "required": ["controllerPath", "hostPath"],
          "additionalProperties": false,
          "properties": {
            "controllerPath": { "type": ["string", "null"] },
            "hostPath": { "type": ["string", "null"] },
            "pagePath": { "type": ["string", "null"] },
            "sharedSourceGroup": { "type": ["string", "null"] }
          }
        },
        "installerHooks": { "$ref": "#/$defs/installerHooks" },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}